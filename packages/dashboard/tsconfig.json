{
	"compilerOptions": {
		"strict": true,
		"target": "ES2023",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": false,
		"sourceMap": true,
		"jsx": "react-jsx",
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src"],
	"references": [{ "path": "../types" }]
}
