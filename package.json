{
	"name": "simvyn-monorepo",
	"type": "module",
	"workspaces": [
		"packages/types",
		"packages/core",
		"packages/server",
		"packages/cli",
		"packages/dashboard",
		"packages/modules/*"
	],
	"scripts": {
		"dev": "npx tsx packages/cli/src/index.ts --no-open & npm run dev -w @simvyn/dashboard",
		"dev:server": "npx tsx packages/cli/src/index.ts --no-open",
		"dev:dashboard": "npm run dev -w @simvyn/dashboard",
		"start": "npx tsx packages/cli/src/index.ts",
		"build": "npm run build -w @simvyn/dashboard",
		"build:cli": "npm run bundle -w simvyn && rm -rf packages/cli/dist/dashboard && cp -r dist/dashboard packages/cli/dist/dashboard",
		"build:release": "npm run build && npm run build:cli && cp README.md packages/cli/README.md",
		"build:all": "npm run build --workspaces --if-present",
		"typecheck": "npx tsc --build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "oxlint .",
		"test": "node --import tsx --test --experimental-test-module-mocks packages/core/src/__tests__/**/*.test.ts"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": "prettier --write"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"devDependencies": {
		"lint-staged": "^16.3.2",
		"oxlint": "^1.50.0",
		"prettier": "^3.8.1",
		"simple-git-hooks": "^2.13.1",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
